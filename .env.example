# Copy this file to `.env` and set values locally.
# `.env` is gitignored; do not commit real secrets.

# Public site URL (for sitemap, canonical links, or future tooling)
SITE_URL=http://localhost:8080

# Optional: hook the signup form to a backend (Formspree, custom API, etc.)
# FORM_ENDPOINT=

# Optional: analytics or other public IDs safe for client-side use
# PUBLIC_ANALYTICS_ID=
