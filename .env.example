# Copy to `.env` and fill values locally.

SITE_URL=http://localhost:8080
# Optional: if omitted, server uses 8080.
# PORT=8080

# Public Supabase client config used by frontend/admin via /api/public-config.
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Одна група для голосування учасників (якщо не використовуєш пару чатів за берегом):
# TELEGRAM_GROUP_CHAT_ID=YOUR_GROUP_NUMERIC_CHAT_ID

# Дві групи — лівий / правий берег (разом із берегом у картці «Місця» в адмінці).
# Якщо обидві задані, TELEGRAM_GROUP_CHAT_ID для голосування ігнорується — чат береться за places.river_bank.
# TELEGRAM_GROUP_CHAT_ID_LEFT_BANK=
# TELEGRAM_GROUP_CHAT_ID_RIGHT_BANK=
